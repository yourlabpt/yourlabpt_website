# Server
PORT=3000
ADMIN_PASSWORD=yourlab-admin

# Chat mode
# - auto: try local models first, fallback to offline lead bot when needed
# - offline: force offline lead bot only (no model calls)
CHAT_MODE=auto

# Local model settings (used only when CHAT_MODE=auto)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_SMALL=phi3:mini
OLLAMA_MODEL_BIG=llama3.1:8b
SMALL_MODEL_TURNS=2
MODEL_TIMEOUT_MS=30000
STICKY_JS_FALLBACK=true
MAX_AI_TURNS_WITHOUT_CONTACT=8

# Session
CHAT_SESSION_TTL_MS=2700000

# Lead notifications
LEAD_NOTIFY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional CORS extras (comma-separated)
ALLOWED_ORIGIN=

# Agent Runtime (YourLab Agent Runtime — local multi-LLM service)
AGENT_RUNTIME_URL=http://127.0.0.1:3847
AGENT_RUNTIME_API_KEY=
AGENT_HMAC_SECRET=
PLATFORM_SERVICE_TOKEN=
# YAR uses this to fetch project context (defaults to http://127.0.0.1:3000)
PLATFORM_BASE_URL=http://127.0.0.1:3000
