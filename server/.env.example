PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=

# Ollama local LLM — run 'ollama serve' before starting the server
# Install examples:
#   ollama pull phi3:mini
#   ollama pull llama3.2:3b
#   ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_BIG=llama3.1:8b
OLLAMA_MODEL_SMALL=phi3:mini
# Switch to big model after this many turns (higher = faster first responses)
SMALL_MODEL_TURNS=6
# Max time to wait for a model response before falling back (ms) — default 30 seconds
MODEL_TIMEOUT_MS=30000
# Context and response-size controls (important for low RAM / CPU machines)
CHAT_HISTORY_TURNS=3
MODEL_MAX_TOKENS=140
MODEL_TEMPERATURE=0.35
MODEL_NUM_CTX=2048
# Lightweight retrieval over company-knowledge.md (no full-file injection per turn)
KNOWLEDGE_CHUNK_MAX_CHARS=420
KNOWLEDGE_SNIPPETS_PER_TURN=2
KNOWLEDGE_SNIPPET_MAX_CHARS=280
# If JS fallback is used once, keep fallback mode for the rest of the session
STICKY_JS_FALLBACK=true
# Safety handoff: after N AI turns without contact, switch to deterministic lead capture
MAX_AI_TURNS_WITHOUT_CONTACT=8

CHAT_SESSION_TTL_MS=2700000
LEAD_NOTIFY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
