PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=

# Ollama local LLM — run 'ollama serve' before starting the server
# Install: https://ollama.com  then: ollama pull llama3.1:8b && ollama pull phi3:mini
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_BIG=llama3.1:8b
OLLAMA_MODEL_SMALL=phi3:mini
# Switch to big model after this many turns (0 = always use big model)
SMALL_MODEL_TURNS=2
# Max time to wait for a model response before falling back (ms) — default 30 seconds
MODEL_TIMEOUT_MS=30000

CHAT_SESSION_TTL_MS=2700000
LEAD_NOTIFY_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
