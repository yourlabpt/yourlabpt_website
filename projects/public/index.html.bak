<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Requirements Platform - YourLab</title>
  <link rel="stylesheet" href="/projects/static/styles.css" />
</head>
<body>
  <div class="page-bg"></div>
  <div class="app" id="root">
    <section class="login-card" id="loginCard">
      <div class="brand">
        <img id="loginLogo" src="/api/logo" alt="YourLab" />
        <div>
          <h1>Requirements Platform</h1>
          <p>Portal central de requisitos, progresso e geração de documentação.</p>
        </div>
      </div>
      <form id="loginForm" class="form-grid">
        <label>
          Email
          <input type="email" id="loginEmail" placeholder="admin@yourlab.local" required />
        </label>
        <label>
          Password
          <input type="password" id="loginPassword" placeholder="••••••••" required />
        </label>
        <button class="btn primary" type="submit">Entrar</button>
      </form>
      <p class="info-text">Super Admin padrão: <code>admin@yourlab.local</code> (password definida no servidor).</p>
      <div id="loginStatus" class="status"></div>
    </section>

    <section id="workspace" class="workspace hidden">
      <header class="topbar">
        <div class="brand">
          <img src="/api/logo" alt="YourLab" />
          <div>
            <h2>Requirements Platform</h2>
            <p>Gestão de requisitos e geração técnica/comercial</p>
          </div>
        </div>
        <div class="topbar-actions">
          <button class="btn ghost btn-theme-toggle" id="themeToggleBtn" title="Alternar tema">🌙</button>
          <div class="user-chip" id="userChip"></div>
          <button class="btn ghost" id="logoutBtn">Sair</button>
        </div>
      </header>

      <main class="layout">
        <aside class="sidebar">
          <div class="panel">
            <div class="panel-title-row">
              <h3>Projetos</h3>
              <button class="btn tiny" id="refreshProjectsBtn">Atualizar</button>
            </div>
            <div id="projectList" class="project-list"></div>
          </div>

          <div class="panel" id="createProjectPanel">
            <h3>Novo Projeto</h3>
            <form id="createProjectForm" class="form-grid compact">
              <label>Nome<input id="newProjectName" required /></label>
              <label>Cliente<input id="newProjectClient" required /></label>
              <label>Rate/h<input id="newProjectRate" type="number" value="30" /></label>
              <label>Moeda<input id="newProjectCurrency" value="EUR" /></label>
              <button class="btn primary" type="submit">Criar</button>
            </form>
          </div>

          <div class="panel" id="usersPanel">
            <h3>Utilizadores</h3>
            <form id="createUserForm" class="form-grid compact">
              <label>Nome<input id="newUserName" required /></label>
              <label>Email<input id="newUserEmail" type="email" required /></label>
              <label>Role
                <select id="newUserRole">
                  <option value="client">Client</option>
                  <option value="partner">Partner</option>
                </select>
              </label>
              <label>Password<input id="newUserPassword" type="text" required /></label>
              <button class="btn primary" type="submit">Criar Utilizador</button>
            </form>
            <div id="usersList" class="simple-list"></div>
          </div>
        </aside>

        <section class="content" id="contentArea">
          <div id="noProject" class="empty-state">
            <h3>Selecione um projeto</h3>
            <p>Escolha um projeto na lateral para abrir requisitos, fases e geração de documentação.</p>
          </div>

          <div id="projectWorkspace" class="hidden">
            <section class="panel">
              <div class="panel-title-row">
                <h3>Visão Clara do Projeto</h3>
              </div>
              <div id="projectKpis" class="kpi-strip"></div>
              <div id="projectReadability" class="readability-grid"></div>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Resumo do Projeto</h3>
                <button class="btn tiny" id="saveProjectBtn">Guardar Alterações</button>
              </div>
              <div class="form-grid" id="projectForm">
                <label>Nome<input id="projectName" /></label>
                <label>Cliente<input id="projectClient" /></label>
                <label>Status
                  <select id="projectStatus">
                    <option value="active">Ativo</option>
                    <option value="on_hold">Em espera</option>
                    <option value="done">Concluído</option>
                  </select>
                </label>
                <label>Proposal Code<input id="projectCode" /></label>
                <label>Rate/h<input id="projectRate" type="number" /></label>
                <label>Moeda<input id="projectCurrency" /></label>
                <label>Idioma<input id="projectLanguage" value="pt-PT" /></label>
                <label>Budget Min<input id="projectBudgetMin" type="number" value="5000" /></label>
                <label>Budget Max<input id="projectBudgetMax" type="number" value="6000" /></label>
                <label class="full">Descrição
                  <textarea id="projectDescription" rows="2"></textarea>
                </label>
                <label class="full">Contexto de negócio
                  <textarea id="summaryBusinessContext" rows="3"></textarea>
                </label>
                <label class="full">Objetivos (1 por linha)
                  <textarea id="summaryGoals" rows="3"></textarea>
                </label>
                <label class="full">Escopo simples (não técnico)
                  <textarea id="summaryScope" rows="3"></textarea>
                </label>
                <label class="full">Visão da solução
                  <textarea id="summarySolution" rows="3"></textarea>
                </label>
              </div>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Membros do Projeto</h3>
              </div>
              <form id="assignMemberForm" class="form-grid compact">
                <label>Utilizador
                  <select id="assignUserId"></select>
                </label>
                <label>Perfil no projeto
                  <select id="assignMemberRole">
                    <option value="client">Client</option>
                    <option value="partner">Partner</option>
                  </select>
                </label>
                <button class="btn primary" type="submit">Associar</button>
              </form>
              <div id="projectMembers" class="simple-list"></div>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Documento do Cliente e Prompt AI</h3>
              </div>
              <form id="uploadDocForm" class="inline-form" enctype="multipart/form-data">
                <input id="docFile" type="file" />
                <button class="btn" type="submit">Carregar Documento</button>
              </form>
              <div id="documentsList" class="simple-list"></div>
              <label class="full">Texto base de requisitos
                <textarea id="sourceText" rows="7" placeholder="Cole aqui o conteúdo extraído do documento do cliente"></textarea>
              </label>
              <div class="actions-row">
                <button class="btn" id="saveSourceTextBtn">Guardar Texto Base</button>
                <button class="btn primary" id="buildPromptBtn">Gerar Pre-Prompt AI</button>
              </div>
              <details class="collapsible">
                <summary>Fluxo AI detalhado (expandir quando necessário)</summary>
                <label class="full">Pre-Prompt gerado
                  <textarea id="aiPrompt" rows="10" readonly></textarea>
                </label>
                <label class="full">Resposta JSON da AI (colar aqui)
                  <textarea id="aiJson" rows="12"></textarea>
                </label>
                <div class="actions-row">
                  <button class="btn primary" id="importAiBtn">Importar Estrutura de Requisitos</button>
                </div>
              </details>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Atas de Reunião (RAW + Histórico)</h3>
              </div>
              <form id="addMeetingMinuteForm" class="form-grid compact">
                <label>Data da reunião
                  <input id="meetingMinuteDate" type="date" />
                </label>
                <label>Título (opcional)
                  <input id="meetingMinuteTitle" placeholder="Ex: Reunião de alinhamento MVP" />
                </label>
                <label class="full">Ata raw (guardada sem transformação)
                  <textarea id="meetingMinuteRaw" rows="7" placeholder="Cole aqui a ata exatamente como foi produzida na reunião..."></textarea>
                </label>
                <button class="btn primary" type="submit">Guardar Ata</button>
              </form>
              <details class="collapsible">
                <summary>Gerar prompt de atualização a partir das atas</summary>
                <label>Objetivo
                  <select id="minutesPromptObjective">
                    <option value="requirements_update">Atualizar requisitos</option>
                    <option value="scope_change">Alteração de escopo</option>
                    <option value="app_description_update">Atualizar descrição/visão da app</option>
                    <option value="full_alignment">Alinhamento completo</option>
                  </select>
                </label>
                <label class="full">Instruções extra (opcional)
                  <textarea id="minutesPromptExtraInstructions" rows="3" placeholder="Ex: Priorizar fase 1 e manter escopo técnico mínimo."></textarea>
                </label>
                <div class="actions-row">
                  <button class="btn primary" type="button" id="buildMinutesPromptBtn">Gerar Prompt com Atas Selecionadas</button>
                </div>
                <label class="full">Prompt gerado
                  <textarea id="minutesPromptOutput" rows="12" readonly></textarea>
                </label>
              </details>
              <div id="minutesHistoryList" class="simple-list"></div>
              <details class="collapsible">
                <summary>Histórico de prompts gerados por atas</summary>
                <div id="minutesPromptHistoryList" class="simple-list"></div>
              </details>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Perguntas de Clarificação (Cliente / Partner)</h3>
              </div>
              <div id="questionsMeta" class="mini-meta"></div>
              <details class="collapsible">
                <summary>Adicionar pergunta</summary>
                <form id="addQuestionForm" class="form-grid compact">
                  <label>Para quem
                    <select id="questionTargetRole">
                      <option value="client">Client</option>
                      <option value="partner">Partner</option>
                      <option value="both">Both</option>
                    </select>
                  </label>
                  <label>Categoria
                    <select id="questionCategory">
                      <option value="scope">Scope</option>
                      <option value="functional">Functional</option>
                      <option value="non_functional">Non-functional</option>
                      <option value="integration">Integration</option>
                      <option value="data">Data</option>
                      <option value="business_rule">Business Rule</option>
                      <option value="ux">UX</option>
                      <option value="security">Security</option>
                      <option value="timeline">Timeline</option>
                      <option value="pricing">Pricing</option>
                      <option value="other">Other</option>
                    </select>
                  </label>
                  <label>Prioridade
                    <select id="questionPriority">
                      <option value="high">Alta</option>
                      <option value="medium" selected>Média</option>
                      <option value="low">Baixa</option>
                    </select>
                  </label>
                  <label>Status
                    <select id="questionStatus">
                      <option value="open" selected>open</option>
                      <option value="sent">sent</option>
                      <option value="answered">answered</option>
                      <option value="resolved">resolved</option>
                      <option value="blocked">blocked</option>
                    </select>
                  </label>
                  <label>Data limite
                    <input id="questionDueDate" type="date" />
                  </label>
                  <label class="full">Pergunta
                    <textarea id="questionText" rows="2" placeholder="Qual parâmetro ou decisão precisa de resposta do cliente/partner?" required></textarea>
                  </label>
                  <label class="full">Contexto (opcional)
                    <textarea id="questionContext" rows="2" placeholder="Explique impacto e por que a resposta é necessária."></textarea>
                  </label>
                  <label class="full">Requisitos ligados (IDs separados por vírgula)
                    <input id="questionLinkedRequirementIds" placeholder="Ex: RF-02, RNF-01" />
                  </label>
                  <button class="btn primary" type="submit">Guardar Pergunta</button>
                </form>
              </details>
              <div class="req-toolbar">
                <select id="questionFilterStatus">
                  <option value="">Todos os status</option>
                </select>
                <select id="questionFilterTargetRole">
                  <option value="">Todos os destinos</option>
                </select>
              </div>
              <div class="table-wrap">
                <table id="questionsTable">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Pergunta</th>
                      <th>Destino</th>
                      <th>Status</th>
                      <th>Prioridade</th>
                      <th>Categoria</th>
                      <th>Requisitos</th>
                      <th>Resposta</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody></tbody>
                </table>
              </div>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Requisitos</h3>
              </div>

              <div class="implementation-plan-wrap">
                <div id="implementationPlanView"></div>
              </div>

              <div class="req-toolbar">
                <input id="reqSearch" placeholder="Pesquisar por ID, título, need, shall..." />
                <select id="reqFilterType">
                  <option value="">Todos os tipos</option>
                  <option value="stakeholder">Stakeholder</option>
                  <option value="functional">Funcional</option>
                  <option value="non_functional">Não funcional</option>
                  <option value="test_case">Teste / Aceite</option>
                  <option value="undefined">Não definido</option>
                  <option value="out_of_scope">Fora de escopo</option>
                </select>
                <select id="reqFilterStatus">
                  <option value="">Todos os status</option>
                </select>
                <select id="reqFilterModule">
                  <option value="">Todos os módulos</option>
                </select>
                <label class="checkline"><input id="reqOnlySmartIssues" type="checkbox" /> Só funcionais com lacunas SMART</label>
              </div>
              <div id="requirementsMeta" class="mini-meta"></div>
              <datalist id="submoduleSuggestions"></datalist>

              <details class="collapsible">
                <summary>Adicionar requisito</summary>
                <form id="addRequirementForm" class="form-grid compact">
                  <label>Tipo
                    <select id="reqType">
                      <option value="stakeholder">Stakeholder</option>
                      <option value="functional">Funcional</option>
                      <option value="non_functional">Não funcional</option>
                      <option value="test_case">Teste / Aceite</option>
                      <option value="undefined">Não definido</option>
                      <option value="out_of_scope">Fora de escopo</option>
                    </select>
                  </label>
                  <label>Título<input id="reqTitle" required /></label>
                  <label>Status
                    <select id="reqStatus"></select>
                  </label>
                  <label>Prioridade
                    <select id="reqPriority">
                      <option value="high">Alta</option>
                      <option value="medium" selected>Média</option>
                      <option value="low">Baixa</option>
                    </select>
                  </label>
                  <label>Fase<input id="reqPhase" placeholder="Fase 1" /></label>
                  <label>Módulo de Arquitetura
                    <select id="reqModule">
                      <option value="Frontend">Frontend</option>
                      <option value="Backend" selected>Backend</option>
                      <option value="Database">Database</option>
                    </select>
                  </label>
                  <label>Submódulo<input id="reqSubmodule" list="submoduleSuggestions" placeholder="Ex: Auth, Coupons, Reporting" /></label>
                  <label class="full">Relaciona com requisitos (IDs separados por vírgula)
                    <input id="reqRelatedIds" placeholder="Ex: RF-02, SR-01" />
                  </label>
                  <label class="full">Descrição<textarea id="reqDescription" rows="2"></textarea></label>
                  <button class="btn primary" type="submit">Adicionar Requisito</button>
                </form>
              </details>

              <div class="requirements-workspace">
                <div class="requirements-list-col">
                  <div class="table-wrap">
                    <table id="requirementsTable">
                      <thead>
                        <tr>
                          <th>ID</th>
                          <th>Tipo</th>
                          <th>Resumo</th>
                        </tr>
                      </thead>
                      <tbody></tbody>
                    </table>
                  </div>
                </div>

                <div class="panel" id="requirementDetailPanel">
                  <div class="panel-title-row">
                    <h3>Requirement Framework Editor</h3>
                    <button class="btn tiny" id="saveRequirementDetailsBtn">Guardar Requisito</button>
                  </div>
                  <div id="requirementDetailEmpty" class="simple-item"><small>Selecione um requisito na tabela para editar o framework completo.</small></div>
                  <div id="requirementQuickView" class="read-card req-quick hidden"></div>
                  <div id="requirementDetailForm" class="form-grid hidden">
                    <label>ID<input id="detailReqId" readonly /></label>
                    <label>Tipo<input id="detailReqType" readonly /></label>
                    <label>Status
                      <select id="detailReqStatus"></select>
                    </label>
                    <label>Prioridade
                      <select id="detailReqPriority">
                        <option value="high">Alta</option>
                        <option value="medium">Média</option>
                        <option value="low">Baixa</option>
                      </select>
                    </label>
                    <label>Fase<input id="detailReqPhase" /></label>
                    <label>Módulo de Arquitetura
                      <select id="detailReqModule">
                        <option value="Frontend">Frontend</option>
                        <option value="Backend">Backend</option>
                        <option value="Database">Database</option>
                      </select>
                    </label>
                    <label>Submódulo<input id="detailReqSubmodule" list="submoduleSuggestions" /></label>
                    <label>Version / Revision<input id="detailReqVersion" placeholder="1.0" /></label>
                    <label class="full">Title / Name<input id="detailReqTitle" /></label>
                    <label class="full">Need<textarea id="detailReqNeed" rows="2" placeholder="As a [stakeholder], I need [need]."></textarea></label>
                    <label class="full">Shall<textarea id="detailReqShall" rows="2" placeholder="The system shall ..."></textarea></label>
                    <label class="full">Condition<textarea id="detailReqCondition" rows="2" placeholder="When [trigger/context/precondition]"></textarea></label>
                    <label class="full">Measure<textarea id="detailReqMeasure" rows="2" placeholder="Passes if [observable result]"></textarea></label>
                    <label class="full">Rationale<textarea id="detailReqRationale" rows="2" placeholder="Needed because ..."></textarea></label>
                    <label class="full">Verification<textarea id="detailReqVerification" rows="2" placeholder="Verified by ..."></textarea></label>
                    <details class="collapsible full">
                      <summary>Campos avançados de rastreabilidade</summary>
                      <label class="full">Assumption (optional)<textarea id="detailReqAssumption" rows="2"></textarea></label>
                      <label>Linked Stakeholder Requirement<input id="detailReqStakeholderLink" /></label>
                      <label>Linked Functional Requirement (for test cases)<input id="detailReqLinkedFunctionalRequirement" /></label>
                      <label class="full">Business Value / Reason<textarea id="detailReqBusinessValue" rows="2"></textarea></label>
                      <label class="full">Target (NFR fields)<textarea id="detailReqTarget" rows="2"></textarea></label>
                      <label class="full">Related Requirement IDs (comma/new line separated)
                        <textarea id="detailReqRelatedIds" rows="2" placeholder="RF-01, SR-03"></textarea>
                      </label>
                      <label class="full">General Notes<textarea id="detailReqNotes" rows="3"></textarea></label>
                    </details>
                    <div class="actions-row full">
                      <button class="btn primary" id="deleteRequirementDetailsBtn">Apagar Requisito</button>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Fases, Riscos e Assunções</h3>
                <button class="btn tiny" id="saveAdvancedBtn">Guardar</button>
              </div>
              <div id="riskAssumptionView" class="readability-grid"></div>
              <details class="collapsible">
                <summary>Editar planeamento avançado</summary>
                <label class="full">Fases (JSON)
                  <textarea id="phasesJson" rows="10"></textarea>
                </label>
                <label class="full">Integrações (JSON)
                  <textarea id="integrationsJson" rows="6"></textarea>
                </label>
                <label class="full">Riscos (1 por linha)
                  <textarea id="risksText" rows="5"></textarea>
                </label>
                <label class="full">Assunções (1 por linha)
                  <textarea id="assumptionsText" rows="5"></textarea>
                </label>
                <label class="full">Termos comerciais (JSON)
                  <textarea id="commercialTermsJson" rows="6"></textarea>
                </label>
                <label class="full">Abordagem técnica (JSON)
                  <textarea id="technicalApproachJson" rows="7"></textarea>
                </label>
              </details>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Gerar Documentação</h3>
              </div>
              <div class="actions-row">
                <button class="btn primary" id="generateTechnicalBtn">Gerar Pacote Técnico</button>
                <button class="btn primary" id="generateCommercialBtn">Gerar Proposta Comercial + Técnica</button>
                <label class="checkline"><input id="dryRunToggle" type="checkbox" /> Dry-run (sem PDF)</label>
              </div>
              <details class="collapsible">
                <summary>Geração modular (opcional)</summary>
                <small>Quando selecionar módulos, a documentação será gerada apenas com os requisitos desses módulos.</small>
                <div id="generationModules" class="module-chip-list"></div>
              </details>
              <div id="generatedLinks" class="simple-list"></div>
            </section>

            <section class="panel">
              <div class="panel-title-row">
                <h3>Atividade</h3>
                <button class="btn tiny" id="refreshActivityBtn">Atualizar</button>
              </div>
              <div id="activityList" class="simple-list"></div>
            </section>
          </div>
        </section>
      </main>

      <footer class="footer-note">
        <span>Requirements Platform by YourLab</span>
        <span>Modelo unificado para requisitos, acompanhamento e propostas.</span>
      </footer>
    </section>
  </div>

  <div id="globalStatus" class="toast hidden"></div>
  <script src="/projects/static/app.js"></script>
</body>
</html>
